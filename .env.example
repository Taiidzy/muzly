# ============ Database Configuration ============
# SQLite (default, for quick start):
# DATABASE_URL=sqlite+aiosqlite:///./muzly.db

# PostgreSQL (for production):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/muzly

# Postgres credentials (only used if PostgreSQL is selected)
POSTGRES_DB=muzly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============ Backend Configuration ============
PORT=8080

# JWT Settings - CHANGE IN PRODUCTION!
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Single-user credentials (used for authentication)
# This project is designed for a single user only
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ============ CORS Configuration ============
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# ============ File Upload Configuration ============
# Maximum upload size in bytes (default: 100MB)
MAX_UPLOAD_SIZE=104857600

# ============ Media Storage ============
# These paths are relative to the backend directory
MEDIA_ROOT=./media
COVERS_ROOT=./covers
IMPORT_DROP=./import_drop

# ============ Logging ============
# SQL_ECHO=true  # Uncomment to enable SQL query logging
